# Copy to .env.local for local development, and add the same two values to
# Vercel → Project → Settings → Environment Variables.
#
# Both are safe to expose in the browser: every row is guarded by row level
# security in Postgres. Never put the service_role key in this file — this app
# has no server component and never needs it.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
